# Copy this file to .env before deploying.

# Required secrets
OPENROUTER_API_KEY=your_primary_openrouter_api_key
TAVILY_API_KEY=your_primary_tavily_api_key
BRAVE_SEARCH_API_KEY=your_brave_search_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional runtime settings
PYAGENT_IMAGE=nousresearch/hermes-agent:latest
PYAGENT_CONTAINER_NAME=pyagent-hermes
TZ=Asia/Kolkata

# Primary and standby models to keep documented in one place.
# Hermes may still ask you to choose one interactively during `hermes setup`.
OPENROUTER_MODEL_PRIMARY=qwen/qwen3.6-plus:free
OPENROUTER_MODEL_FALLBACK=nvidia/nemotron-3-super-120b-a12b:free
