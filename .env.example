# Copy this file to .env before deploying.

# Required secrets
OPENROUTER_API_KEY=your_openrouter_api_key
TAVILY_API_KEY=your_tavily_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional runtime settings
PYAGENT_IMAGE=nousresearch/hermes-agent:latest
PYAGENT_CONTAINER_NAME=pyagent-hermes
TZ=Asia/Kolkata

# Suggested OpenRouter model identifier to pick during `hermes setup`
OPENROUTER_MODEL=openai/gpt-4.1-mini

