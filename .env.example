# Copy this file to .env before deploying.

# Required secrets
OPENROUTER_API_KEY=your_primary_openrouter_api_key
TAVILY_API_KEY=your_primary_tavily_api_key
BRAVE_SEARCH_API_KEY=your_brave_search_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
PYAGENT_PROXY_API_KEY=set_a_local_shared_secret_for_hermes

# Optional runtime settings
PYAGENT_IMAGE=nousresearch/hermes-agent:latest
PYAGENT_CONTAINER_NAME=pyagent-hermes
TZ=Asia/Kolkata
OPENROUTER_TIMEOUT_SECONDS=45

# Primary and standby models to keep documented in one place.
# Hermes should be configured to use the primary model during `hermes setup`.
# The proxy retries fallback models on upstream rate-limit/server failures.
OPENROUTER_MODEL_PRIMARY=qwen/qwen3.6-plus:free
OPENROUTER_MODEL_FALLBACK_1=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_FALLBACK_2=arcee-ai/trinity-large-preview:free
OPENROUTER_MODEL_FALLBACK_3=stepfun/step-3.5-flash:free
